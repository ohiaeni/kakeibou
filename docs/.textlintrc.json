{
  "plugins": {},
  "filters": {
    "comments": true
  },
  "rules": {
    "preset-ja-technical-writing": {
      "@textlint-ja/no-synonyms": false
    },
    "preset-ja-spacing": {
      "ja-space-between-half-and-full-width": {
        "space": "always"
      },
      "ja-space-around-code": {
        "before": true,
        "after": true
      }
    },
    "@textlint-ja/textlint-rule-no-synonyms": true,
    "@textlint-rule/textlint-rule-require-header-id": false,
    "ja-no-orthographic-variants": true
  },
  "ignorePatterns": [".github/**/*", "node_modules/**/*"]
}
